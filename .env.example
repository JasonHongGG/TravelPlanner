# TravelPlannerDashboard environment template
# This repo uses two runtime env files:
# - frontend/.env: Vite variables must start with VITE_
# - backend/.env: server, persistence, and AI provider variables

################################
# Frontend App (frontend/.env) #
################################

# Google OAuth client id used by the browser app.
VITE_GOOGLE_CLIENT_ID=

# Vite dev server.
VITE_PORT=3000
# Optional comma-separated list of allowed Vite dev server hosts.
# VITE_ALLOWED_HOSTS=travelplanner.alberthongtunnel.dpdns.org

# Backend API base URLs used by the browser app.
VITE_API_BASE_URL=http://localhost:3001
VITE_DB_API_URL=http://localhost:3002

#############################
# Backend App (backend/.env) #
#############################

# Google OAuth audience for backend token verification.
GOOGLE_CLIENT_ID=

# Production security keys. Leave blank in local development unless needed.
TRIP_ENCRYPTION_KEY=
TRIP_EVENT_TOKEN_SECRET=
TRIP_EVENT_TOKEN_TTL_MS=600000

#################################
# Backend AI Provider Selection #
#################################

# AI_PROVIDER options:
# - copilot: routes AI calls through the local Copilot helper server.
# - gemini: calls Google AI Studio Gemini API with GEMINI_API_KEY.
# - vertex: calls Google Cloud Vertex AI Gemini with ADC/service account auth.
# - ollama: calls an Ollama /api/chat endpoint.
# - local_api: calls a custom local API with /generate, /update, /recommend, /feasibility endpoints.
AI_PROVIDER=copilot

##########################################
# Provider: Copilot (AI_PROVIDER=copilot) #
##########################################

GITHUB_TOKEN=
COPILOT_SERVER_URL=http://localhost:3003/process
COPILOT_LOG_DIR=
COPILOT_MODEL=gpt-5.2
COPILOT_TRIP_GENERATOR_MODEL=
COPILOT_TRIP_UPDATER_MODEL=
COPILOT_RECOMMENDER_MODEL=gemini-3-flash

########################################
# Provider: Gemini (AI_PROVIDER=gemini) #
########################################

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-pro-preview
GEMINI_TRIP_GENERATOR_MODEL=
GEMINI_TRIP_UPDATER_MODEL=
GEMINI_RECOMMENDER_MODEL=gemini-3-flash-preview

########################################
# Provider: Vertex (AI_PROVIDER=vertex) #
########################################

# Vertex uses Application Default Credentials. For local dev, run:
# gcloud auth application-default login
# For service account JSON outside GCP, set GOOGLE_APPLICATION_CREDENTIALS.
# Do not commit service account keys.
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=
VERTEX_API_VERSION=v1
VERTEX_MODEL=gemini-2.5-flash
VERTEX_TRIP_GENERATOR_MODEL=
VERTEX_TRIP_UPDATER_MODEL=
VERTEX_RECOMMENDER_MODEL=
VERTEX_TEMPERATURE=0.2
VERTEX_MAX_OUTPUT_TOKENS=4096

########################################
# Provider: Ollama (AI_PROVIDER=ollama) #
########################################

OLLAMA_BASE_URL=https://example.ngrok-free.app
OLLAMA_MODEL=gpt-oss:120b
OLLAMA_TRIP_GENERATOR_MODEL=
OLLAMA_TRIP_UPDATER_MODEL=llama3.3:70b
OLLAMA_RECOMMENDER_MODEL=gemma3:12b

############################################
# Provider: Local API (AI_PROVIDER=local_api) #
############################################

LOCAL_API_BASE_URL=/local-api
LOCAL_API_MODEL=gemini-3-pro-thinking
LOCAL_API_TRIP_GENERATOR_MODEL=
LOCAL_API_TRIP_UPDATER_MODEL=
LOCAL_API_RECOMMENDER_MODEL=gemini-3-flash

#########################
# Backend Network Ports #
#########################

PORT=3001
DB_SERVER_PORT=3002
COPILOT_SERVER_PORT=3003

#############################
# Backend Internal Services #
#############################

DB_SERVER_URL=http://localhost:3002

################
# Backend CORS #
################

FRONTEND_ORIGINS=http://localhost:5173,http://localhost:3000

#############################
# Backend Runtime Artifacts #
#############################

DATA_DIR=
GENERATION_JOB_TTL_MS=86400000
GENERATION_JOB_ACKED_RESULT_TTL_MS=900000
