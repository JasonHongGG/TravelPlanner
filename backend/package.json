{
    "name": "travel-planner-backend",
    "version": "1.0.0",
    "description": "Backend services for Travel Planner Dashboard",
    "type": "module",
    "main": "src/index.ts",
    "scripts": {
        "clean:build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
        "build": "npm run clean:build && tsc -p tsconfig.json",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "test": "tsx --test src/**/*.test.ts ../shared/**/*.test.ts",
        "test:contracts": "tsx --test ../shared/**/*.test.ts",
        "lint": "npm run typecheck",
        "migrate:report": "tsx src/scripts/createMigrationReport.ts",
        "copilot:logs:parse": "tsx src/scripts/parseCopilotLogs.ts",
        "smoke:vertex": "tsx src/scripts/vertexSmokeTest.ts",
        "db": "tsx src/dbServer.ts",
        "copilot": "tsx src/copilotServer.ts",
        "server": "tsx src/server.ts",
        "install-deps": "npm install"
    },
    "dependencies": {
        "@github/copilot-sdk": "^0.1.12",
        "@google/genai": "^1.37.0",
        "cors": "^2.8.5",
        "dotenv": "^17.2.3",
        "express": "^5.2.1",
        "google-auth-library": "^9.15.1",
        "uuid": "^13.0.0",
        "winston": "^3.19.0"
    },
    "devDependencies": {
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/node": "^22.14.0",
        "@types/uuid": "^10.0.0",
        "tsx": "^4.21.0",
        "typescript": "~5.8.2"
    }
}
