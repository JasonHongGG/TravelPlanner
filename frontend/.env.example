# Frontend (Vite) environment variables.
# Copy this file to frontend/.env and fill in the values.
# IMPORTANT: Vite only exposes variables prefixed with VITE_ to the browser.

########################
# Frontend Google Auth #
########################

VITE_GOOGLE_CLIENT_ID=

#######################
# Frontend Dev Server #
#######################

VITE_PORT=3000
# Comma-separated list of allowed hosts for Vite dev server (optional)
# VITE_ALLOWED_HOSTS=travelplanner.alberthongtunnel.dpdns.org

#####################
# Frontend API URLs #
#####################

VITE_API_BASE_URL=http://localhost:3001
VITE_DB_API_URL=http://localhost:3002
